&GLOBAL
  PROJECT cp2k
  PRINT_LEVEL LOW
  RUN_TYPE DRIVER
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  &SUBSYS
    &CELL
      A 11.2201                0.0                       0.0
      B -5.6100502014000000    9.7168919818999999        0.0
      C 0.0000000000000000    0.0000000000000000   45.0000000000000000
      PERIODIC XYZ

    &END CELL
    &TOPOLOGY
      COORD_FILE_FORMAT XYZ
      COORD_FILE_NAME init.xyz
    &END TOPOLOGY
    &KIND H
      ELEMENT H
      BASIS_SET TZV2P-MOLOPT-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
    &KIND Ne
      ELEMENT Ne
      BASIS_SET DZVP-MOLOPT-SR-GTH-q8
      POTENTIAL GTH-PBE-q8
      CORE_CORRECTION 0.0
    &END KIND
    &KIND O
      ELEMENT O
      BASIS_SET TZV2P-MOLOPT-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND Pt
      ELEMENT Pt
      BASIS_SET DZVP-MOLOPT-SR-GTH-q18
      POTENTIAL GTH-PBE-q18
    &END KIND
  &END SUBSYS

  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    CHARGE 0
    MULTIPLICITY 1
    CORE_CORR_DIP TRUE
    SURFACE_DIPOLE_CORRECTION TRUE
    SURF_DIP_DIR Z
    #SURF_DIP_POS 40.0
    &MGRID
      CUTOFF 400
      REL_CUTOFF 50
    &END MGRID
    &QS
      METHOD GPW
      EPS_DEFAULT 1.0E-10
      EXTRAPOLATION USE_GUESS
      EXTRAPOLATION_ORDER 3
    &END QS
	
    &SCF
      SCF_GUESS ATOMIC
      ADDED_MOS 100
      EPS_SCF 1.0E-5
      MAX_SCF 5000
      &SMEAR ON
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 300
      &END SMEAR
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.2
        BETA 0.5
        NBROYDEN 8
      &END MIXING
    &END SCF
	
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          PARAMETER_FILE_NAME dftd3.dat
          TYPE DFTD3(BJ)
          REFERENCE_FUNCTIONAL PBE
          #CALCULATE_C9_TERM T #Calculate C9-related three-body term, more accurate for large system
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC
	
    &PRINT
      &MULLIKEN OFF
      &END MULLIKEN
      &V_HARTREE_CUBE OFF
      &END V_HARTREE_CUBE
    &END PRINT
  &END DFT
&END FORCE_EVAL

&MOTION
  &DRIVER
    HOST localhost
    PORT 18003
  &END DRIVER
&END MOTION
