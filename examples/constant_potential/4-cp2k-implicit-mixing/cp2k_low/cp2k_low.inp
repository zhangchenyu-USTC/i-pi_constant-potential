&GLOBAL
  PROJECT cp2k_low
  RUN_TYPE DRIVER
  PRINT_LEVEL LOW
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  STRESS_TENSOR NONE

  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    CHARGE 0

    &MGRID
      CUTOFF 400
      REL_CUTOFF 50
      NGRIDS 5
    &END MGRID

    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER IMPLICIT
      &IMPLICIT
        BOUNDARY_CONDITIONS PERIODIC
        MAX_ITER 1000
        OR_PARAMETER 0.1
        TOL 1.0E-4
        &DIELECTRIC
          DERIVATIVE_METHOD CD5
          DIELECTRIC_CONSTANT 78.36
          DIELECTRIC_CORE_CORRECTION .TRUE.
          RHO_MAX 1.0E-3
          RHO_MIN 1.0E-4
        &END DIELECTRIC
      &END IMPLICIT
    &END POISSON

    &QS
      METHOD GPW
      EPS_DEFAULT 1.0E-10
      EXTRAPOLATION USE_GUESS
      EXTRAPOLATION_ORDER 3
    &END QS

    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 1.0E-5
      MAX_SCF 1000
      ADDED_MOS 100
      &SMEAR ON
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 300
      &END SMEAR
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.2
        BETA 0.5
        NBROYDEN 8
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF

    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          PARAMETER_FILE_NAME dftd3.dat
          TYPE DFTD3(BJ)
          REFERENCE_FUNCTIONAL PBE
          #CALCULATE_C9_TERM T #Calculate C9-related three-body term, more accurate for large system
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC

    &PRINT
      &IMPLICIT_PSOLVER
        &DIELECTRIC_CUBE OFF
        &END DIELECTRIC_CUBE
      &END IMPLICIT_PSOLVER
      &E_DENSITY_CUBE OFF
      &END E_DENSITY_CUBE
      &EFIELD_CUBE OFF
      &END EFIELD_CUBE
    &END PRINT
  &END DFT

  &SUBSYS
    &CELL
      A 9.9204 0.0 0.0
      B 0.0 8.5913 0.0
      C 0.0 0.0 20.0
      PERIODIC XYZ
    &END CELL

    &TOPOLOGY
      COORD_FILE_NAME ../36Al.xyz
      COORD_FILE_FORMAT XYZ
    &END TOPOLOGY

    &KIND Al
      ELEMENT Al
      BASIS_SET DZVP-MOLOPT-SR-GTH-q3
      POTENTIAL GTH-PBE
    &END KIND
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &DRIVER
    HOST localhost
    PORT 19001
  &END DRIVER
&END MOTION

