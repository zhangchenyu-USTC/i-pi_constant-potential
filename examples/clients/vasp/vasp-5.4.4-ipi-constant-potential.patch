+      SUBROUTINE PARSE_IPI_REAL_TOKEN(INPUT_STRING,TOKEN,VALUE,FOUND,OK)
+      CHARACTER(LEN=*), INTENT(IN) :: INPUT_STRING, TOKEN
+      REAL(q), INTENT(OUT) :: VALUE
+      LOGICAL, INTENT(OUT) :: FOUND, OK
+      INTEGER :: TOKEN_POS, COLON_POS, START_POS, END_POS, IOS
+
+      FOUND = .FALSE.
+      OK = .TRUE.
+      TOKEN_POS = INDEX(INPUT_STRING,TRIM(TOKEN))
+      IF (TOKEN_POS<=0) RETURN
+
+      COLON_POS = INDEX(INPUT_STRING(TOKEN_POS:),':')
+      IF (COLON_POS<=0) THEN
+        OK = .FALSE.
+        RETURN
+      ENDIF
+      START_POS = TOKEN_POS + COLON_POS
+      DO WHILE (START_POS<=LEN_TRIM(INPUT_STRING))
+        IF (INPUT_STRING(START_POS:START_POS)/=' ' .AND. &
+     &      INPUT_STRING(START_POS:START_POS)/=',' .AND. &
+     &      INPUT_STRING(START_POS:START_POS)/=';') EXIT
+        START_POS = START_POS + 1
+      ENDDO
+      IF (START_POS>LEN_TRIM(INPUT_STRING)) THEN
+        OK = .FALSE.
+        RETURN
+      ENDIF
+
+      END_POS = START_POS
+      DO WHILE (END_POS<=LEN_TRIM(INPUT_STRING))
+        IF (INPUT_STRING(END_POS:END_POS)==',' .OR. &
+     &      INPUT_STRING(END_POS:END_POS)==';') EXIT
+        END_POS = END_POS + 1
+      ENDDO
+      READ(INPUT_STRING(START_POS:END_POS-1),*,IOSTAT=IOS) VALUE
+      IF (IOS/=0) THEN
+        OK = .FALSE.
+        RETURN
+      ENDIF
+      IF (.NOT. IEEE_IS_FINITE(VALUE)) THEN
+        OK = .FALSE.
+        RETURN
+      ENDIF
+      FOUND = .TRUE.
+      END SUBROUTINE PARSE_IPI_REAL_TOKEN
