+      SUBROUTINE POTENTIAL_AVERAGE_FROM_CVTOT(GRIDC, LATT_CUR, CVTOT, AXIS, &
+     &                                        REGION_MIN_A, REGION_MAX_A, VAC_LEVEL_EV)
+      USE prec
+      USE mgrid
+      USE lattice
+      IMPLICIT NONE
+
+      TYPE (grid_3d) GRIDC
+      TYPE (latt)    LATT_CUR
+      RGRID CVTOT(GRIDC%RL%NP)
+      INTEGER :: AXIS
+      REAL(q) :: REGION_MIN_A, REGION_MAX_A
+      REAL(q) :: VAC_LEVEL_EV
+      INTEGER :: GRID_INDEX, GRID_SIZE(3), ISTAT, N_IN, NX, NY, NZ
+      REAL(q), ALLOCATABLE :: WORK(:,:,:)
+      REAL(q) :: CELL_HEIGHT, COORDINATE, CROSS_VECTOR(3), FACE_NORM
+      REAL(q) :: SUM_IN_REGION
+
+      GRID_SIZE = (/GRIDC%NGX,GRIDC%NGY,GRIDC%NGZ/)
+      IF (ANY(GRID_SIZE<=0)) THEN
+         WRITE(*,*) 'ERROR: Invalid FFT grid in POTENTIAL_AVERAGE_FROM_CVTOT.'
+         STOP
+      ENDIF
+      IF (AXIS<1 .OR. AXIS>3) THEN
+         WRITE(*,*) 'ERROR: potential_average_axis must be x, y, or z.'
+         STOP
+      ENDIF
+      ALLOCATE(WORK(GRIDC%NGX,GRIDC%NGY,GRIDC%NGZ), STAT=ISTAT)
+      IF (ISTAT>0) THEN
+         WRITE(*,*) 'ERROR: Failed to allocate potential-average work grid.'
+         STOP
+      ENDIF
+
+      SELECT CASE (AXIS)
+      CASE (1)
+         CROSS_VECTOR(1)=LATT_CUR%A(2,2)*LATT_CUR%A(3,3)-LATT_CUR%A(3,2)*LATT_CUR%A(2,3)
+         CROSS_VECTOR(2)=LATT_CUR%A(3,2)*LATT_CUR%A(1,3)-LATT_CUR%A(1,2)*LATT_CUR%A(3,3)
+         CROSS_VECTOR(3)=LATT_CUR%A(1,2)*LATT_CUR%A(2,3)-LATT_CUR%A(2,2)*LATT_CUR%A(1,3)
+      CASE (2)
+         CROSS_VECTOR(1)=LATT_CUR%A(2,3)*LATT_CUR%A(3,1)-LATT_CUR%A(3,3)*LATT_CUR%A(2,1)
+         CROSS_VECTOR(2)=LATT_CUR%A(3,3)*LATT_CUR%A(1,1)-LATT_CUR%A(1,3)*LATT_CUR%A(3,1)
+         CROSS_VECTOR(3)=LATT_CUR%A(1,3)*LATT_CUR%A(2,1)-LATT_CUR%A(2,3)*LATT_CUR%A(1,1)
+      CASE (3)
+         CROSS_VECTOR(1)=LATT_CUR%A(2,1)*LATT_CUR%A(3,2)-LATT_CUR%A(3,1)*LATT_CUR%A(2,2)
+         CROSS_VECTOR(2)=LATT_CUR%A(3,1)*LATT_CUR%A(1,2)-LATT_CUR%A(1,1)*LATT_CUR%A(3,2)
+         CROSS_VECTOR(3)=LATT_CUR%A(1,1)*LATT_CUR%A(2,2)-LATT_CUR%A(2,1)*LATT_CUR%A(1,2)
+      END SELECT
+      FACE_NORM=SQRT(SUM(CROSS_VECTOR*CROSS_VECTOR))
+      IF (FACE_NORM<=0._q .OR. LATT_CUR%OMEGA<=0._q) THEN
+         WRITE(*,*) 'ERROR: Invalid lattice for planar potential averaging.'
+         STOP
+      ENDIF
+      CELL_HEIGHT=LATT_CUR%OMEGA/FACE_NORM
+      IF (REGION_MIN_A<0._q .OR. REGION_MAX_A<=REGION_MIN_A .OR. &
+     &    REGION_MAX_A>CELL_HEIGHT+1.E-10_q) THEN
+         WRITE(*,*) 'ERROR: potential_average_region is outside the selected cell height.'
+         STOP
+      ENDIF
+
+      CALL MRG_GRID_RL(GRIDC,WORK,CVTOT)
+
+      SUM_IN_REGION = 0._q
+      N_IN = 0
+      DO NZ=1,GRIDC%NGZ
+      DO NY=1,GRIDC%NGY
+      DO NX=1,GRIDC%NGX
+         SELECT CASE (AXIS)
+         CASE (1)
+            GRID_INDEX=NX-1
+         CASE (2)
+            GRID_INDEX=NY-1
+         CASE (3)
+            GRID_INDEX=NZ-1
+         END SELECT
+         COORDINATE=REAL(GRID_INDEX,q)/REAL(GRID_SIZE(AXIS),q)*CELL_HEIGHT
+         IF (COORDINATE.GE.REGION_MIN_A .AND. COORDINATE.LE.REGION_MAX_A) THEN
+            SUM_IN_REGION=SUM_IN_REGION+WORK(NX,NY,NZ)
+            N_IN=N_IN+1
+         ENDIF
+      ENDDO
+      ENDDO
+      ENDDO
+
+      IF (N_IN>0) THEN
+         VAC_LEVEL_EV = SUM_IN_REGION / REAL(N_IN, q)
+      ELSE
+         WRITE(*,*) 'ERROR: No FFT grid points fall inside potential_average_region.'
+         STOP
+      ENDIF
+
+      DEALLOCATE(WORK)
+
+      RETURN
+      END SUBROUTINE
+
 
