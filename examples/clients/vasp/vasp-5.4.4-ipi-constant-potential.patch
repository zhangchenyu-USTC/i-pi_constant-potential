+              P(NE_SPECIES_TYPE)%ZVALF      = ZVAL_NE_CURRENT
+              NE_DOPING_MODE = .TRUE.
+
+              IF (COMM%NODE_ME == 1) THEN
+                WRITE(TIU0,*) ' @ DRIVER MODE: Ne-electrode CHGDATA target NELECT = ', INFO%NELECT, &
+     &                         ', neutral_electrons = ', NEUTRAL_ELECTRONS_REF
