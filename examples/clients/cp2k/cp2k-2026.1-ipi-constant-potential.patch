+! **************************************************************************************************
+!> \brief   Apply an integer total electron count received from i-PI.
+!>
+!> The CHGDATA value is interpreted as the target total electron number. CP2K
+!> keeps the user-provided spin setup and multiplicity; incompatible integer
+!> electron counts abort explicitly instead of being rounded or repaired.
+! **************************************************************************************************
+   SUBROUTINE apply_cp2k_nelect(force_env, target_nelect)
+
+      TYPE(force_env_type), POINTER                      :: force_env
+      REAL(KIND=dp), INTENT(IN)                          :: target_nelect
+
+      CHARACTER(LEN=*), PARAMETER                        :: routineN = 'apply_cp2k_nelect'
+
+      INTEGER :: current_nelect, handle, homo, ifill, ispin, lfomo, multiplicity, needed_mos, &
+         nelectron_spin(2), neutral_nelect, new_charge, nmo, nspins, target_int
+      LOGICAL                                            :: state_unchanged
+      REAL(KIND=dp)                                      :: delta, maxocc, remaining_occ
+      REAL(KIND=dp), DIMENSION(:), POINTER               :: occupation_numbers
+      TYPE(dft_control_type), POINTER                    :: dft_control
+      TYPE(mo_set_type), DIMENSION(:), POINTER           :: mos
+      TYPE(qs_environment_type), POINTER                 :: qs_env
+      TYPE(qs_kind_type), DIMENSION(:), POINTER          :: qs_kind_set
+      TYPE(qs_ks_env_type), POINTER                      :: ks_env
+      TYPE(qs_subsys_type), POINTER                      :: qs_subsys
+
+      CALL timeset(routineN, handle)
+
+      target_int = NINT(target_nelect)
+      delta = ABS(target_nelect - REAL(target_int, KIND=dp))
+      IF (delta > 1.0e-8_dp) THEN
+         CPABORT("CHGDATA target electron number for CP2K must be an integer.")
+      END IF
+      IF (target_int <= 0) THEN
+         CPABORT("CHGDATA target electron number for CP2K must be positive.")
+      END IF
+
+      NULLIFY (qs_env)
+      CALL force_env_get(force_env, qs_env=qs_env)
+      IF (.NOT. ASSOCIATED(qs_env)) THEN
+         CPABORT("CHGDATA electron-number update requires a QS force environment.")
+      END IF
+
+      NULLIFY (qs_kind_set)
+      NULLIFY (qs_subsys)
+      NULLIFY (dft_control)
+      NULLIFY (mos)
+      NULLIFY (ks_env)
+      CALL get_qs_env(qs_env=qs_env, qs_kind_set=qs_kind_set, subsys=qs_subsys, &
+                      dft_control=dft_control, mos=mos, ks_env=ks_env)
+
+      IF (.NOT. ASSOCIATED(qs_kind_set)) THEN
+         CPABORT("CHGDATA electron-number update could not access qs_kind_set.")
+      END IF
+      IF (.NOT. ASSOCIATED(qs_subsys)) THEN
+         CPABORT("CHGDATA electron-number update could not access qs_subsys.")
+      END IF
+      IF (.NOT. ASSOCIATED(dft_control)) THEN
+         CPABORT("CHGDATA electron-number update could not access dft_control.")
+      END IF
+
+      neutral_nelect = 0
+      CALL get_qs_kind_set(qs_kind_set, nelectron=neutral_nelect)
+      IF (neutral_nelect <= 0) THEN
+         CPABORT("CHGDATA electron-number update could not determine neutral electron count.")
+      END IF
+
+      new_charge = neutral_nelect - target_int
+      nspins = dft_control%nspins
+      multiplicity = dft_control%multiplicity
+      nelectron_spin(:) = 0
+
+      IF (nspins == 1) THEN
+         IF (MODULO(target_int, 2) /= 0 .AND. .NOT. dft_control%smear) THEN
+            CPABORT("CP2K single-spin CHGDATA update received an odd electron count. Use UKS/LSD.")
+         END IF
+         nelectron_spin(1) = target_int
+      ELSEIF (nspins == 2) THEN
+         IF (multiplicity <= 0) THEN
+            CPABORT("CP2K CHGDATA update requires an explicit MULTIPLICITY for UKS/LSD.")
+         END IF
+         IF (MODULO(target_int + multiplicity - 1, 2) /= 0) THEN
+            CPABORT("CP2K CHGDATA update is incompatible with the current MULTIPLICITY.")
+         END IF
+         nelectron_spin(1) = (target_int + multiplicity - 1)/2
+         nelectron_spin(2) = (target_int - multiplicity + 1)/2
+         IF (nelectron_spin(2) < 0) THEN
+            CPABORT("CP2K CHGDATA update has too few electrons for the current MULTIPLICITY.")
+         END IF
+      ELSE
+         CPABORT("CP2K CHGDATA update supports only NSPIN 1 or 2.")
+      END IF
+
+      ! Preserve the converged OT orbitals when a fixed charge-mixing endpoint
+      ! receives the same electron count on consecutive force requests. Rewriting
+      ! identical occupations and marking the potential as changed destroys OT
+      ! continuation and can add hundreds of unnecessary SCF iterations.
+      current_nelect = -1
+      CALL qs_subsys_get_qs(qs_subsys, nelectron_total=current_nelect)
+      state_unchanged = current_nelect == target_int .AND. &
+                        dft_control%charge == new_charge
+
+      IF (state_unchanged) THEN
+         CALL timestop(handle)
+         RETURN
+      END IF
+
+      dft_control%charge = new_charge
+      CALL qs_subsys_set_qs(qs_subsys, nelectron_total=target_int, nelectron_spin=nelectron_spin)
+
+      IF (ASSOCIATED(mos)) THEN
+         IF (SIZE(mos) < nspins) THEN
+            CPABORT("CP2K CHGDATA update found fewer MO sets than spin channels.")
+         END IF
+
+         DO ispin = 1, nspins
+            NULLIFY (occupation_numbers)
+            maxocc = 0.0_dp
+            nmo = 0
+            CALL get_mo_set(mos(ispin), maxocc=maxocc, nmo=nmo, &
+                            occupation_numbers=occupation_numbers)
+
+            IF (maxocc <= 0.0_dp) THEN
+               CPABORT("CP2K CHGDATA update found an invalid MO occupation capacity.")
+            END IF
+
+            needed_mos = 0
+            IF (nelectron_spin(ispin) > 0) THEN
+               needed_mos = CEILING(REAL(nelectron_spin(ispin), KIND=dp)/maxocc - 1.0e-12_dp)
+            END IF
+            IF (needed_mos > nmo) THEN
+               CPABORT("CP2K CHGDATA update needs more MOs. Increase ADDED_MOS in the CP2K input.")
+            END IF
+
+            CALL set_mo_set(mos(ispin), nelectron=nelectron_spin(ispin), &
+                            n_el_f=REAL(nelectron_spin(ispin), KIND=dp))
+
+            IF (ASSOCIATED(occupation_numbers)) THEN
+               occupation_numbers(:) = 0.0_dp
+               remaining_occ = REAL(nelectron_spin(ispin), KIND=dp)
+               ifill = 0
+               DO WHILE (remaining_occ > maxocc - 1.0e-12_dp)
+                  ifill = ifill + 1
+                  occupation_numbers(ifill) = maxocc
+                  remaining_occ = remaining_occ - maxocc
+               END DO
+
+               IF (remaining_occ > 1.0e-12_dp) THEN
+                  ifill = ifill + 1
+                  occupation_numbers(ifill) = remaining_occ
+               END IF
+
+               homo = ifill
+               lfomo = MIN(homo + 1, nmo)
+               CALL set_mo_set(mos(ispin), homo=homo, lfomo=lfomo)
+            END IF
+         END DO
+      END IF
+
+      IF (ASSOCIATED(ks_env)) THEN
+         CALL set_ks_env(ks_env, potential_changed=.TRUE., &
+                         forces_up_to_date=.FALSE.)
+      END IF
+
+      CALL timestop(handle)
+
+   END SUBROUTINE apply_cp2k_nelect
+
