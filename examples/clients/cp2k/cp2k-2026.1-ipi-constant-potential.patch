 CONTAINS
 
+! **************************************************************************************************
+!> \brief Get fermi level, electron count, and optional workfunction for extras JSON
+!> \param force_env The force environment
+!> \param potential_average_axis Lattice axis (1=x, 2=y, 3=z)
+!> \param potential_average_min Minimum perpendicular coordinate in Angstrom
+!> \param potential_average_max Maximum perpendicular coordinate in Angstrom
+!> \param extras_json JSON string with extras information
+! **************************************************************************************************
+   SUBROUTINE get_extras_json(force_env, potential_average_axis, potential_average_min, &
+                              potential_average_max, extras_json)
+      TYPE(force_env_type), POINTER                      :: force_env
+      INTEGER, INTENT(IN)                                :: potential_average_axis
+      REAL(KIND=dp), INTENT(IN)                          :: potential_average_min, &
+                                                            potential_average_max
+      CHARACTER(LEN=*), INTENT(OUT)                      :: extras_json
+
+      CHARACTER(len=*), PARAMETER                        :: routineN = 'get_extras_json'
+
+      CHARACTER(LEN=24)                                  :: fermi_str, nelect_str, workfunction_str
+      INTEGER                                            :: handle, homo, ispin, nelect_int, nmo, &
+                                                            nspin
+      LOGICAL                                            :: have_workfunction
+      REAL(KIND=dp)                                      :: fermi_hartree, fermi_level_eV, &
+                                                            nelect_real, workfunction_eV
+      REAL(KIND=dp), DIMENSION(:), POINTER               :: mo_eigenvalues
+      TYPE(cp_fm_type), POINTER                          :: mo_coeff
+      TYPE(dbcsr_p_type), DIMENSION(:), POINTER          :: matrix_ks
+      TYPE(dft_control_type), POINTER                    :: dft_control
+      TYPE(mo_set_type), DIMENSION(:), POINTER           :: mos
+      TYPE(qs_energy_type), POINTER                      :: energy
+      TYPE(qs_environment_type), POINTER                 :: qs_env
+      TYPE(qs_subsys_type), POINTER                      :: qs_subsys
+
+      CALL timeset(routineN, handle)
+      have_workfunction = .FALSE.
+
+      NULLIFY (qs_env)
+      CALL force_env_get(force_env, qs_env=qs_env)
+      IF (.NOT. ASSOCIATED(qs_env)) THEN
+         CPABORT("CP2K i-PI constant-potential extras require a QS force environment.")
+      END IF
+
+      NULLIFY (energy)
+      NULLIFY (mos)
+      NULLIFY (qs_subsys)
+      NULLIFY (dft_control)
+      NULLIFY (matrix_ks)
+      NULLIFY (mo_coeff)
+      NULLIFY (mo_eigenvalues)
+      CALL get_qs_env(qs_env, energy=energy, mos=mos, subsys=qs_subsys, &
+                      dft_control=dft_control, matrix_ks=matrix_ks)
+      IF (.NOT. ASSOCIATED(energy)) THEN
+         CPABORT("CP2K i-PI constant-potential extras could not access QS energy data.")
+      END IF
+
+      fermi_hartree = energy%efermi
+      IF (fermi_hartree == 0.0_dp) THEN
+         IF (.NOT. ASSOCIATED(mos)) THEN
+            CPABORT("CP2K i-PI Fermi level is unset and no MO chemical potential is available.")
+         END IF
+         IF (SIZE(mos) <= 0) CPABORT("CP2K i-PI MO array is empty.")
+         nspin = SIZE(mos)
+         fermi_hartree = 0.0_dp
+         DO ispin = 1, nspin
+            IF (.NOT. IEEE_IS_FINITE(mos(ispin)%mu)) THEN
+               CPABORT("CP2K i-PI MO chemical potential is not finite.")
+            END IF
+            fermi_hartree = fermi_hartree + mos(ispin)%mu
+         END DO
+         fermi_hartree = fermi_hartree/REAL(nspin, KIND=dp)
+      END IF
+      IF (ABS(fermi_hartree) <= 10.0_dp*EPSILON(fermi_hartree)) THEN
+         ! Standard OT does not populate mo_set%mu or energy%efermi. Compute
+         ! the occupied-subspace Ritz eigenvalues from the converged KS matrix
+         ! and use the HOMO as the zero-temperature electronic chemical potential.
+         IF (.NOT. ASSOCIATED(mos) .OR. .NOT. ASSOCIATED(matrix_ks)) THEN
+            CPABORT("CP2K i-PI OT Fermi fallback requires MO and KS-matrix data.")
+         END IF
+         IF (SIZE(matrix_ks) < SIZE(mos)) THEN
+            CPABORT("CP2K i-PI OT Fermi fallback found too few KS matrices.")
+         END IF
+         IF (ASSOCIATED(dft_control)) THEN
+            IF (dft_control%do_admm) THEN
+               CPABORT("CP2K i-PI OT Fermi fallback does not yet support ADMM.")
+            END IF
+         END IF
+         nspin = SIZE(mos)
+         fermi_hartree = 0.0_dp
+         DO ispin = 1, nspin
+            NULLIFY (mo_coeff)
+            NULLIFY (mo_eigenvalues)
+            homo = 0
+            nmo = 0
+            CALL get_mo_set(mos(ispin), mo_coeff=mo_coeff, &
+                            eigenvalues=mo_eigenvalues, homo=homo, nmo=nmo)
+            IF (.NOT. ASSOCIATED(mo_coeff) .OR. .NOT. ASSOCIATED(mo_eigenvalues)) THEN
+               CPABORT("CP2K i-PI OT Fermi fallback could not access occupied orbitals.")
+            END IF
+            IF (homo <= 0 .OR. homo > nmo .OR. homo > SIZE(mo_eigenvalues)) THEN
+               CPABORT("CP2K i-PI OT Fermi fallback found an invalid HOMO index.")
+            END IF
+            CALL calculate_subspace_eigenvalues(orbitals=mo_coeff, &
+                                                ks_matrix=matrix_ks(ispin)%matrix, &
+                                                evals_arg=mo_eigenvalues, &
+                                                do_rotation=.FALSE.)
+            IF (.NOT. IEEE_IS_FINITE(mo_eigenvalues(homo))) THEN
+               CPABORT("CP2K i-PI OT HOMO energy is not finite.")
+            END IF
+            fermi_hartree = fermi_hartree + mo_eigenvalues(homo)
+         END DO
+         fermi_hartree = fermi_hartree/REAL(nspin, KIND=dp)
+      END IF
+      IF (.NOT. IEEE_IS_FINITE(fermi_hartree)) THEN
+         CPABORT("CP2K i-PI Fermi level is not finite.")
+      END IF
+      IF (ABS(fermi_hartree) <= 10.0_dp*EPSILON(fermi_hartree)) THEN
+         CPABORT("CP2K i-PI Fermi level remains unset after the OT fallback.")
+      END IF
+      fermi_level_eV = fermi_hartree*HARTREE_TO_EV
+
+      nelect_real = 0.0_dp
+      IF (ASSOCIATED(qs_subsys)) THEN
+         CALL qs_subsys_get_qs(qs_subsys, nelectron_total=nelect_int)
+         IF (nelect_int > 0) nelect_real = REAL(nelect_int, KIND=dp)
+      END IF
+      IF (nelect_real <= 0.0_dp .AND. ASSOCIATED(mos)) THEN
+         nspin = SIZE(mos)
+         DO ispin = 1, nspin
+            nelect_real = nelect_real + REAL(mos(ispin)%nelectron, KIND=dp)
+         END DO
+      END IF
+      IF (.NOT. IEEE_IS_FINITE(nelect_real) .OR. nelect_real <= 0.0_dp) THEN
+         CPABORT("CP2K i-PI constant-potential extras could not determine a valid electron count.")
+      END IF
+
+      IF (potential_average_max > potential_average_min) THEN
+         CALL compute_workfunction_from_vhartree(force_env, potential_average_axis, &
+                                                 potential_average_min, potential_average_max, &
+                                                 fermi_level_eV, workfunction_eV)
+         IF (.NOT. IEEE_IS_FINITE(workfunction_eV)) THEN
+            CPABORT("CP2K i-PI workfunction is not finite.")
+         END IF
+         have_workfunction = .TRUE.
+      END IF
+
+      WRITE (fermi_str, '(ES24.16E3)') fermi_level_eV
+      WRITE (nelect_str, '(ES24.16E3)') nelect_real
+      extras_json = '{"fermi_level_eV": '//TRIM(ADJUSTL(fermi_str))// &
+                    ', "nelect": '//TRIM(ADJUSTL(nelect_str))
+      IF (have_workfunction) THEN
+         WRITE (workfunction_str, '(ES24.16E3)') workfunction_eV
+         extras_json = TRIM(extras_json)// &
+                       ', "workfunction_eV": '//TRIM(ADJUSTL(workfunction_str))
+      END IF
+      extras_json = TRIM(extras_json)//'}'
+
+      CALL timestop(handle)
+   END SUBROUTINE get_extras_json
+
+! **************************************************************************************************
+!> \brief Compute a workfunction from the latest cube-equivalent Hartree average.
+!>
+!> The average is updated during the GPW post-SCF path, before the force-building path
+!> modifies v_hartree_rspace for one-center force integrations.
+! **************************************************************************************************
+   SUBROUTINE compute_workfunction_from_vhartree(force_env, axis, minimum_A, maximum_A, &
+                                                 fermi_level_eV, workfunction_eV)
+      TYPE(force_env_type), POINTER                      :: force_env
+      INTEGER, INTENT(IN)                                :: axis
+      REAL(KIND=dp), INTENT(IN)                          :: minimum_A, maximum_A, fermi_level_eV
+      REAL(KIND=dp), INTENT(OUT)                         :: workfunction_eV
+
+      CHARACTER(LEN=*), PARAMETER :: routineN = 'compute_workfunction_from_vhartree'
+
+      INTEGER                                            :: handle
+      LOGICAL                                            :: average_available
+      REAL(KIND=dp)                                      :: v_avg_hartree
+
+      CALL timeset(routineN, handle)
+
+      IF (axis < 1 .OR. axis > 3) THEN
+         CPABORT("CP2K i-PI workfunction update requires axis x, y, or z.")
+      END IF
+      IF (maximum_A <= minimum_A) THEN
+         CPABORT("CP2K i-PI workfunction update requires potential_average_max_A > min_A.")
+      END IF
+
+      CALL ipi_workfunction_get_average(v_avg_hartree, average_available)
+      IF (.NOT. average_available) THEN
+         CPABORT("CP2K i-PI workfunction update did not receive a post-SCF Hartree average.")
+      END IF
+      workfunction_eV = v_avg_hartree*HARTREE_TO_EV - fermi_level_eV
+
+      CALL timestop(handle)
+   END SUBROUTINE compute_workfunction_from_vhartree
+
+! **************************************************************************************************
+!> \brief Parse the i-PI INIT string for a real-valued token.
+! **************************************************************************************************
+   SUBROUTINE parse_init_real_token(init_string, token, value, found)
+      CHARACTER(LEN=*), INTENT(IN)                       :: init_string, token
+      REAL(KIND=dp), INTENT(OUT)                         :: value
+      LOGICAL, INTENT(OUT)                               :: found
+
+      CHARACTER(LEN=:), ALLOCATABLE                      :: value_string
+      INTEGER                                            :: colon_pos, end_pos, ios, start_pos, &
+                                                            token_pos
+
+      found = .FALSE.
+      token_pos = INDEX(init_string, TRIM(token))
+      IF (token_pos <= 0) RETURN
+
+      colon_pos = INDEX(init_string(token_pos:), ":")
+      IF (colon_pos <= 0) CPABORT("Malformed i-PI INIT token: missing ':'.")
+
+      start_pos = token_pos + colon_pos
+      DO WHILE (start_pos <= LEN_TRIM(init_string))
+         IF (init_string(start_pos:start_pos) /= " " .AND. &
+             init_string(start_pos:start_pos) /= "," .AND. &
+             init_string(start_pos:start_pos) /= ";") EXIT
+         start_pos = start_pos + 1
+      END DO
+      IF (start_pos > LEN_TRIM(init_string)) CPABORT("Malformed i-PI INIT token: missing value.")
+
+      end_pos = start_pos
+      DO WHILE (end_pos <= LEN_TRIM(init_string))
+         IF (init_string(end_pos:end_pos) == "," .OR. init_string(end_pos:end_pos) == ";") EXIT
+         end_pos = end_pos + 1
+      END DO
+
+      value_string = init_string(start_pos:end_pos - 1)
+      READ (value_string, *, IOSTAT=ios) value
+      IF (ios /= 0 .OR. .NOT. IEEE_IS_FINITE(value)) THEN
+         CPABORT("Malformed i-PI INIT token: value is not a finite real number.")
+      END IF
+      found = .TRUE.
+   END SUBROUTINE parse_init_real_token
+
+! **************************************************************************************************
+!> \brief Parse an x/y/z lattice-axis token from the i-PI INIT string.
+! **************************************************************************************************
+   SUBROUTINE parse_init_axis_token(init_string, token, axis, found)
+      CHARACTER(LEN=*), INTENT(IN)                       :: init_string, token
+      INTEGER, INTENT(OUT)                               :: axis
+      LOGICAL, INTENT(OUT)                               :: found
+
+      INTEGER                                            :: colon_pos, start_pos, token_pos
+
+      found = .FALSE.
+      axis = 0
+      token_pos = INDEX(init_string, TRIM(token))
+      IF (token_pos <= 0) RETURN
+      colon_pos = INDEX(init_string(token_pos:), ":")
+      IF (colon_pos <= 0) CPABORT("Malformed i-PI INIT axis token: missing ':'.")
+      start_pos = token_pos + colon_pos
+      DO WHILE (start_pos <= LEN_TRIM(init_string))
+         IF (init_string(start_pos:start_pos) /= " " .AND. &
+             init_string(start_pos:start_pos) /= "," .AND. &
+             init_string(start_pos:start_pos) /= ";") EXIT
+         start_pos = start_pos + 1
+      END DO
+      IF (start_pos > LEN_TRIM(init_string)) CPABORT("Malformed i-PI INIT axis token: missing value.")
+      SELECT CASE (init_string(start_pos:start_pos))
+      CASE ("x", "X")
+         axis = 1
+      CASE ("y", "Y")
+         axis = 2
+      CASE ("z", "Z")
+         axis = 3
+      CASE DEFAULT
+         CPABORT("CP2K i-PI INIT potential_average_axis must be x, y, or z.")
+      END SELECT
+      found = .TRUE.
+   END SUBROUTINE parse_init_axis_token
+
+! **************************************************************************************************
+!> \brief Parse i-PI INIT parameters used by constant-potential CP2K driver mode.
+! **************************************************************************************************
+   SUBROUTINE parse_ipi_init_string(init_string, potential_average_axis, &
+                                    potential_average_min, potential_average_max, &
+                                    neutral_electrons_ref, solvation_update_stride, &
+                                    solvation_update_stride_declared)
+      CHARACTER(LEN=*), INTENT(IN)                       :: init_string
+      INTEGER, INTENT(INOUT)                             :: potential_average_axis
+      REAL(KIND=dp), INTENT(INOUT)                       :: potential_average_min, &
+                                                            potential_average_max, &
+                                                            neutral_electrons_ref
+      INTEGER, INTENT(INOUT)                             :: solvation_update_stride
+      LOGICAL, INTENT(OUT) :: solvation_update_stride_declared
+
+      INTEGER                                            :: parsed_axis
+      LOGICAL                                            :: found_axis, found_maximum, &
+                                                            found_minimum, found_neutral, &
+                                                            found_stride
+      REAL(KIND=dp)                                      :: maximum, minimum, neutral_ref, &
+                                                            stride_real
+
+      minimum = potential_average_min
+      maximum = potential_average_max
+      neutral_ref = neutral_electrons_ref
+      CALL parse_init_axis_token(init_string, "potential_average_axis", parsed_axis, found_axis)
+      CALL parse_init_real_token(init_string, "potential_average_min_A", minimum, found_minimum)
+      CALL parse_init_real_token(init_string, "potential_average_max_A", maximum, found_maximum)
+      CALL parse_init_real_token(init_string, "neutral_electrons", neutral_ref, found_neutral)
+      CALL parse_init_real_token(init_string, "solvation_update_stride", stride_real, found_stride)
+
+      IF ((found_axis .NEQV. found_minimum) .OR. (found_axis .NEQV. found_maximum)) THEN
+         CPABORT("CP2K i-PI INIT must contain potential_average_axis and both region bounds.")
+      END IF
+
+      IF (found_axis) THEN
+         IF (maximum <= minimum) THEN
+            CPABORT("CP2K i-PI INIT requires potential_average_max_A > min_A.")
+         END IF
+         potential_average_axis = parsed_axis
+         potential_average_min = minimum
+         potential_average_max = maximum
+      END IF
+
+      IF (found_neutral) THEN
+         IF (neutral_ref <= 0.0_dp) THEN
+            CPABORT("CP2K i-PI INIT requires neutral_electrons > 0 for Ne-electrode mode.")
+         END IF
+         neutral_electrons_ref = neutral_ref
+      END IF
+
+      solvation_update_stride_declared = found_stride
+      IF (found_stride) THEN
+         IF (stride_real < 1.0_dp .OR. ABS(stride_real - ANINT(stride_real)) > 1.0e-12_dp) THEN
+            CPABORT("CP2K i-PI INIT solvation_update_stride must be a positive integer.")
+         END IF
+         solvation_update_stride = NINT(stride_real)
+      END IF
+   END SUBROUTINE parse_ipi_init_string
