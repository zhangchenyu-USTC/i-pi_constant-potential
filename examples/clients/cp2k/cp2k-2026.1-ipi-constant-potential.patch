+      INTEGER, INTENT(IN)                                :: axis
+      REAL(KIND=dp), INTENT(IN)                          :: minimum_A, maximum_A
+
+      IF (axis < 1 .OR. axis > 3) CPABORT("CP2K i-PI potential_average_axis must be x, y, or z.")
