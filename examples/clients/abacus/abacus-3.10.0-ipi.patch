@@ -0,0 +1,59 @@
+#ifndef MODULE_IPI_PROTOCOL_H
+#define MODULE_IPI_PROTOCOL_H
+
+#include <cstdint>
+#include <string>
+#include <vector>
+
+namespace ModuleIPI
+{
+
+enum class MessageType
+{
+    Status,
+    Init,
+    PosData,
+    GetForce,
+    Exit,
+    Unknown
+};
+
+class IpiSocket
+{
+  public:
+    IpiSocket();
+    ~IpiSocket();
+
+    IpiSocket(const IpiSocket&) = delete;
+    IpiSocket& operator=(const IpiSocket&) = delete;
+
+    void connect_socket(const std::string& mode, const std::string& host, int port);
+    void close_socket();
+
+    MessageType recv_header(std::string& raw_header);
+    void send_header(const std::string& header);
+
+    void read_int32(std::int32_t& value);
+    void read_float64(double& value);
+    void read_float64_array(double* data, std::size_t count);
+    void read_string(std::string& value, std::size_t count);
+
+    void write_int32(std::int32_t value);
+    void write_float64(double value);
+    void write_float64_array(const double* data, std::size_t count);
+    void write_string(const std::string& value);
+
+  private:
+    int fd_;
+
+    void read_exact(void* data, std::size_t bytes);
+    void write_exact(const void* data, std::size_t bytes);
+};
+
+std::string make_header(const std::string& text);
+std::string trim_header(const std::string& text);
+MessageType parse_header(const std::string& raw_header);
+
+} // namespace ModuleIPI
+
+#endif // MODULE_IPI_PROTOCOL_H
