diff --git a/source/module_ipi/ipi_protocol.cpp b/source/module_ipi/ipi_protocol.cpp
new file mode 100644
index 0000000..81d0778
--- /dev/null
+++ b/source/module_ipi/ipi_protocol.cpp
@@ -0,0 +1,306 @@
+#include "ipi_protocol.h"
+
+#include "module_base/tool_quit.h"
+
+#include <cerrno>
+#include <cstring>
+#include <netdb.h>
+#include <stdexcept>
+#include <sys/socket.h>
+#include <sys/un.h>
+#include <unistd.h>
+
+namespace ModuleIPI
+{
+namespace
+{
+const std::size_t HDRLEN = 12;
+
+std::string socket_error(const std::string& prefix)
+{
+    return prefix + ": " + std::strerror(errno);
+}
+
+void quit_with_error(const std::string& where, const std::string& message)
+{
+    ModuleBase::WARNING_QUIT(where, message);
+}
+} // namespace
+
+IpiSocket::IpiSocket() : fd_(-1)
+{
+}
+
+IpiSocket::~IpiSocket()
+{
+    close_socket();
+}
+
+void IpiSocket::connect_socket(const std::string& mode, const std::string& host, int port)
+{
+    close_socket();
+
+    if (mode == "inet")
+    {
+        struct addrinfo hints;
+        std::memset(&hints, 0, sizeof(hints));
+        hints.ai_family = AF_INET;
+        hints.ai_socktype = SOCK_STREAM;
+
+        struct addrinfo* result = nullptr;
+        const std::string port_str = std::to_string(port);
+        const int gai = getaddrinfo(host.c_str(), port_str.c_str(), &hints, &result);
+        if (gai != 0)
+        {
+            quit_with_error("IpiSocket::connect_socket", std::string("getaddrinfo failed: ") + gai_strerror(gai));
+        }
+
+        for (struct addrinfo* rp = result; rp != nullptr; rp = rp->ai_next)
+        {
+            fd_ = socket(rp->ai_family, rp->ai_socktype, rp->ai_protocol);
+            if (fd_ == -1)
+            {
+                continue;
+            }
+            if (::connect(fd_, rp->ai_addr, rp->ai_addrlen) == 0)
+            {
+                break;
+            }
+            close_socket();
+        }
+        freeaddrinfo(result);
+
+        if (fd_ == -1)
+        {
+            quit_with_error("IpiSocket::connect_socket", socket_error("cannot connect inet socket"));
+        }
+    }
+    else if (mode == "unix")
+    {
+        fd_ = socket(AF_UNIX, SOCK_STREAM, 0);
+        if (fd_ == -1)
+        {
+            quit_with_error("IpiSocket::connect_socket", socket_error("cannot create unix socket"));
+        }
+
+        std::string path = host;
+        if (path.empty())
+        {
+            path = "localhost";
+        }
+        if (path[0] != '/')
+        {
+            path = "/tmp/ipi_" + path;
+        }
+
+        struct sockaddr_un addr;
+        std::memset(&addr, 0, sizeof(addr));
+        addr.sun_family = AF_UNIX;
+        if (path.size() >= sizeof(addr.sun_path))
+        {
+            quit_with_error("IpiSocket::connect_socket", "unix socket path is too long: " + path);
+        }
+        std::strncpy(addr.sun_path, path.c_str(), sizeof(addr.sun_path) - 1);
+
+        if (::connect(fd_, reinterpret_cast<struct sockaddr*>(&addr), sizeof(addr)) != 0)
+        {
+            const std::string msg = socket_error("cannot connect unix socket " + path);
+            close_socket();
+            quit_with_error("IpiSocket::connect_socket", msg);
+        }
+    }
+    else
+    {
+        quit_with_error("IpiSocket::connect_socket", "ipi_mode must be 'inet' or 'unix', got '" + mode + "'");
+    }
+}
+
+void IpiSocket::close_socket()
+{
+    if (fd_ >= 0)
+    {
+        ::close(fd_);
+        fd_ = -1;
+    }
+}
+
+MessageType IpiSocket::recv_header(std::string& raw_header)
+{
+    char buf[HDRLEN];
+    read_exact(buf, HDRLEN);
+    raw_header.assign(buf, HDRLEN);
+    return parse_header(raw_header);
+}
+
+void IpiSocket::send_header(const std::string& header)
+{
+    const std::string wire = make_header(header);
+    write_exact(wire.data(), wire.size());
+}
+
+void IpiSocket::read_int32(std::int32_t& value)
+{
+    read_exact(&value, sizeof(value));
+}
+
+void IpiSocket::read_float64(double& value)
+{
+    read_exact(&value, sizeof(value));
+}
+
+void IpiSocket::read_float64_array(double* data, std::size_t count)
+{
+    if (count > 0)
+    {
+        read_exact(data, count * sizeof(double));
+    }
+}
+
+void IpiSocket::read_string(std::string& value, std::size_t count)
+{
+    value.assign(count, '\0');
+    if (count > 0)
+    {
+        read_exact(&value[0], count);
+    }
+}
+
+void IpiSocket::write_int32(std::int32_t value)
+{
+    write_exact(&value, sizeof(value));
+}
+
+void IpiSocket::write_float64(double value)
+{
+    write_exact(&value, sizeof(value));
+}
+
+void IpiSocket::write_float64_array(const double* data, std::size_t count)
+{
+    if (count > 0)
+    {
+        write_exact(data, count * sizeof(double));
+    }
+}
+
+void IpiSocket::write_string(const std::string& value)
+{
+    if (!value.empty())
+    {
+        write_exact(value.data(), value.size());
+    }
+}
+
+void IpiSocket::read_exact(void* data, std::size_t bytes)
+{
+    char* ptr = static_cast<char*>(data);
+    std::size_t done = 0;
+    while (done < bytes)
+    {
+        const ssize_t nread = ::read(fd_, ptr + done, bytes - done);
+        if (nread == 0)
+        {
+            quit_with_error("IpiSocket::read_exact", "socket closed by peer");
+        }
+        if (nread < 0)
+        {
+            if (errno == EINTR)
+            {
+                continue;
+            }
+            quit_with_error("IpiSocket::read_exact", socket_error("socket read failed"));
+        }
+        done += static_cast<std::size_t>(nread);
+    }
+}
+
+void IpiSocket::write_exact(const void* data, std::size_t bytes)
+{
+    const char* ptr = static_cast<const char*>(data);
+    std::size_t done = 0;
+    while (done < bytes)
+    {
+        const ssize_t nwritten = ::write(fd_, ptr + done, bytes - done);
+        if (nwritten == 0)
+        {
+            quit_with_error("IpiSocket::write_exact", "socket closed while writing");
+        }
+        if (nwritten < 0)
+        {
+            if (errno == EINTR)
+            {
+                continue;
+            }
+            quit_with_error("IpiSocket::write_exact", socket_error("socket write failed"));
+        }
+        done += static_cast<std::size_t>(nwritten);
+    }
+}
+
+std::string make_header(const std::string& text)
+{
+    std::string header = text;
+    for (std::size_t i = 0; i < header.size(); ++i)
+    {
+        if (header[i] >= 'a' && header[i] <= 'z')
+        {
+            header[i] = static_cast<char>(header[i] - 'a' + 'A');
+        }
+    }
+    if (header.size() > HDRLEN)
+    {
+        header.resize(HDRLEN);
+    }
+    else
+    {
+        header.append(HDRLEN - header.size(), ' ');
+    }
+    return header;
+}
+
+std::string trim_header(const std::string& text)
+{
+    std::size_t begin = 0;
+    while (begin < text.size() && text[begin] == ' ')
+    {
+        ++begin;
+    }
+    std::size_t end = text.size();
+    while (end > begin && text[end - 1] == ' ')
+    {
+        --end;
+    }
+    return text.substr(begin, end - begin);
+}
+
+MessageType parse_header(const std::string& raw_header)
+{
+    const std::string header = trim_header(raw_header);
+    if (header == "STATUS")
+    {
+        return MessageType::Status;
+    }
+    if (header == "INIT")
+    {
+        return MessageType::Init;
+    }
+    if (header == "POSDATA")
+    {
+        return MessageType::PosData;
+    }
+    if (header == "CHGDATA")
+    {
+        return MessageType::ChgData;
+    }
+    if (header == "GETFORCE")
+    {
+        return MessageType::GetForce;
+    }
+    if (header == "EXIT")
+    {
+        return MessageType::Exit;
+    }
+    return MessageType::Unknown;
+}
+
+} // namespace ModuleIPI
