+
+void IPIDriver::run(UnitCell& ucell, ModuleESolver::ESolver* p_esolver)
+{
+    ModuleBase::TITLE("IPIDriver", "run");
+
+    if (p_esolver == nullptr)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::run", "ESolver pointer is null");
+    }
+
+    IpiSocket socket;
+    connect_socket_if_root(socket);
+
+    bool needs_init = true;
+    bool has_data = false;
+    bool stop = false;
+    int istep = 0;
+    ForceResult result;
+
+    while (!stop)
+    {
+        std::string raw_header;
+        const MessageType message = receive_message(socket, raw_header);
+        if (is_root())
+        {
+            GlobalV::ofs_running << " @IPI DRIVER: Message from i-PI: " << trim_header(raw_header) << std::endl;
+        }
+
+        switch (message)
+        {
+        case MessageType::Status:
+            if (is_root())
+            {
+                if (needs_init)
+                {
+                    socket.send_header("NEEDINIT");
+                }
+                else if (has_data)
+                {
+                    socket.send_header("HAVEDATA");
+                }
+                else
+                {
+                    socket.send_header("READY");
+                }
+            }
+            break;
+
+        case MessageType::Init:
+            handle_init(socket, p_esolver);
+            needs_init = false;
+            break;
+
+        case MessageType::ChgData:
+            if (has_data)
+            {
+                ModuleBase::WARNING_QUIT("IPIDriver::run", "received CHGDATA while previous force data are still pending");
+            }
+            receive_chgdata(socket, p_esolver);
+            break;
+
+        case MessageType::PosData:
+            if (has_data)
+            {
+                ModuleBase::WARNING_QUIT("IPIDriver::run", "received POSDATA while previous force data are still pending");
+            }
+            receive_posdata(socket, ucell);
+            compute_force(ucell, p_esolver, istep, result);
+            has_data = true;
+            ++istep;
+            break;
+
+        case MessageType::GetForce:
+            if (!has_data || !result.valid)
+            {
+                ModuleBase::WARNING_QUIT("IPIDriver::run", "received GETFORCE before force data were computed");
+            }
+            send_force(socket, ucell, result);
+            result.valid = false;
+            has_data = false;
+            break;
+
+        case MessageType::Exit:
+            stop = true;
+            break;
+
+        default:
+            ModuleBase::WARNING_QUIT("IPIDriver::run", "unknown i-PI message header: " + trim_header(raw_header));
+        }
+    }
+
+    socket.close_socket();
+    if (is_root())
+    {
+        GlobalV::ofs_running << " @IPI DRIVER: Exiting i-PI driver loop." << std::endl;
+    }
+}
+
+void IPIDriver::connect_socket_if_root(IpiSocket& socket) const
+{
+    if (!is_root())
+    {
+        return;
+    }
+
+    GlobalV::ofs_running << " @IPI DRIVER: Connecting to i-PI using mode=" << PARAM.inp.ipi_mode
+                         << " host=" << PARAM.inp.ipi_host
+                         << " port=" << PARAM.inp.ipi_port << std::endl;
+    socket.connect_socket(PARAM.inp.ipi_mode, PARAM.inp.ipi_host, PARAM.inp.ipi_port);
+    GlobalV::ofs_running << " @IPI DRIVER: Connected to i-PI." << std::endl;
+}
+
+MessageType IPIDriver::receive_message(IpiSocket& socket, std::string& raw_header) const
+{
+    int message_value = static_cast<int>(MessageType::Unknown);
+    if (is_root())
+    {
+        const MessageType message = socket.recv_header(raw_header);
+        message_value = static_cast<int>(message);
+    }
+    broadcast_int(message_value);
+
+    if (!is_root())
+    {
+        raw_header = make_header(message_name(static_cast<MessageType>(message_value)));
+    }
+    return static_cast<MessageType>(message_value);
+}
+
+void IPIDriver::handle_init(IpiSocket& socket, ModuleESolver::ESolver* p_esolver)
+{
+    std::int32_t rid = 0;
+    std::int32_t init_len = 0;
+    std::string init_string;
+    int has_potential_average_region = 0;
+    int potential_average_axis = 2;
+    double potential_average_min_A = 0.0;
+    double potential_average_max_A = 0.0;
+    int solvation_update_stride = 1;
+    int solvation_update_stride_declared = 0;
+
+    if (is_root())
+    {
+        socket.read_int32(rid);
+        socket.read_int32(init_len);
+        if (init_len < 0 || init_len > MAX_INIT_BYTES)
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::handle_init",
+                                     "INIT string length must be between 0 and 1 MiB");
+        }
+        socket.read_string(init_string, static_cast<std::size_t>(init_len));
+        GlobalV::ofs_running << " @IPI DRIVER: Received INIT rid=" << rid
+                             << " length=" << init_len << std::endl;
+        if (!init_string.empty())
+        {
+            GlobalV::ofs_running << " @IPI DRIVER: INIT string: " << init_string << std::endl;
+        }
+
+        std::string parsed_axis;
+        double parsed_minimum_A = 0.0;
+        double parsed_maximum_A = 0.0;
+        const bool has_axis = extract_init_string(init_string, "potential_average_axis", parsed_axis);
+        const bool has_minimum
+            = extract_init_double(init_string, "potential_average_min_A", parsed_minimum_A);
+        const bool has_maximum
+            = extract_init_double(init_string, "potential_average_max_A", parsed_maximum_A);
+        if (has_axis != has_minimum || has_axis != has_maximum)
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::handle_init",
+                                     "INIT must provide potential_average_axis and both region bounds");
+        }
+        if (has_axis)
+        {
+            std::transform(parsed_axis.begin(), parsed_axis.end(), parsed_axis.begin(),
+                           [](unsigned char c) { return static_cast<char>(std::tolower(c)); });
+            if (parsed_axis.size() != 1 || parsed_axis[0] < 'x' || parsed_axis[0] > 'z')
+            {
+                ModuleBase::WARNING_QUIT("IPIDriver::handle_init",
+                                         "INIT potential_average_axis must be x, y, or z");
+            }
+            if (parsed_maximum_A <= parsed_minimum_A)
+            {
+                ModuleBase::WARNING_QUIT("IPIDriver::handle_init",
+                                         "INIT potential_average_max_A must exceed potential_average_min_A");
+            }
+            has_potential_average_region = 1;
+            potential_average_axis = static_cast<int>(parsed_axis[0] - 'x');
+            potential_average_min_A = parsed_minimum_A;
+            potential_average_max_A = parsed_maximum_A;
+            GlobalV::ofs_running << " @IPI DRIVER: Workfunction potential_average_axis="
+                                 << parsed_axis << " region=[" << std::setprecision(12)
+                                 << potential_average_min_A << ", " << potential_average_max_A
+                                 << "] Angstrom" << std::endl;
+        }
+
+        double parsed_neutral_electrons = 0.0;
+        if (extract_init_double(init_string, "neutral_electrons", parsed_neutral_electrons))
+        {
+            if (parsed_neutral_electrons <= 0.0)
+            {
+                ModuleBase::WARNING_QUIT("IPIDriver::handle_init",
+                                         "INIT neutral_electrons must be positive");
+            }
+            GlobalV::ofs_running << " @IPI DRIVER: Parsed neutral_electrons from INIT: "
+                                 << std::setprecision(12) << parsed_neutral_electrons << std::endl;
+        }
+
+        double parsed_stride = 0.0;
+        if (extract_init_double(init_string, "solvation_update_stride", parsed_stride))
+        {
+            if (parsed_stride < 1.0 || std::abs(parsed_stride - std::round(parsed_stride)) > 1.0e-12)
+            {
+                ModuleBase::WARNING_QUIT("IPIDriver::handle_init",
+                                         "INIT solvation_update_stride must be a positive integer");
+            }
+            solvation_update_stride = static_cast<int>(std::round(parsed_stride));
+            solvation_update_stride_declared = 1;
+        }
+    }
+
+    broadcast_int(has_potential_average_region);
+    broadcast_int(potential_average_axis);
+    broadcast_double(potential_average_min_A);
+    broadcast_double(potential_average_max_A);
+    broadcast_int(solvation_update_stride);
+    broadcast_int(solvation_update_stride_declared);
+
+    this->has_potential_average_region_ = (has_potential_average_region != 0);
+    this->potential_average_axis_ = potential_average_axis;
+    this->potential_average_min_A_ = potential_average_min_A;
+    this->potential_average_max_A_ = potential_average_max_A;
+    this->solvation_update_stride_ = solvation_update_stride;
+    this->solvation_update_stride_declared_ = (solvation_update_stride_declared != 0);
+
+    if (this->solvation_update_stride_declared_ && this->solvation_update_stride_ > 1)
+    {
+        if (!PARAM.inp.imp_sol)
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::handle_init",
+                                     "solvation_update_stride>1 requires imp_sol=1 in ABACUS INPUT");
+        }
+        if (p_esolver == nullptr || !p_esolver->configure_ipi_solvation(this->solvation_update_stride_))
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::handle_init",
+                                     "the selected ABACUS ESolver cannot freeze a complete implicit-solvent state");
+        }
+    }
+}
+
+void IPIDriver::receive_chgdata(IpiSocket& socket, ModuleESolver::ESolver* p_esolver) const
+{
+    double target_nelect = 0.0;
+    std::int32_t flag = 0;
+
+    if (is_root())
+    {
+        socket.read_float64(target_nelect);
+        socket.read_int32(flag);
+    }
+    broadcast_double(target_nelect);
+    broadcast_int32(flag);
+
+    apply_nelect(target_nelect, flag, p_esolver);
+}
+
+void IPIDriver::apply_nelect(double target_nelect, std::int32_t flag, ModuleESolver::ESolver* p_esolver) const
+{
+    if (flag < 0 || flag > IPI_FLAG_SOLVATION + IPI_FLAG_NE_ELECTRODE)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect",
+                                 "unsupported i-PI CHGDATA mode_flags value");
+    }
+    if (!std::isfinite(target_nelect) || target_nelect <= 0.0)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect", "CHGDATA target electron number must be finite and positive");
+    }
+    if (PARAM.inp.nspin != 1 && PARAM.inp.nspin != 2)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect", "CHGDATA currently supports only nspin=1 or nspin=2");
+    }
+    if (PARAM.globalv.two_fermi && PARAM.inp.nspin != 2)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect",
+                                 "ABACUS two_fermi/nupdown mode requires nspin=2 for CHGDATA");
+    }
+    if (PARAM.inp.ocp)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect",
+                                 "CHGDATA is incompatible with fixed occupation arrays from INPUT ocp");
+    }
+    if (PARAM.inp.nbands <= 0)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect", "nbands must be positive before applying CHGDATA");
+    }
+
+    if (PARAM.globalv.two_fermi)
+    {
+        const double nelec_up = 0.5 * (target_nelect + PARAM.inp.nupdown);
+        const double nelec_down = 0.5 * (target_nelect - PARAM.inp.nupdown);
+        if (nelec_up < -1.0e-8 || nelec_down < -1.0e-8)
+        {
+            std::ostringstream oss;
+            oss << "CHGDATA target nelect=" << std::setprecision(12) << target_nelect
+                << " with nupdown=" << PARAM.inp.nupdown
+                << " gives invalid spin electron counts: up=" << nelec_up
+                << ", down=" << nelec_down;
+            ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect", oss.str());
+        }
+        if (nelec_up > static_cast<double>(PARAM.inp.nbands) + 1.0e-8
+            || nelec_down > static_cast<double>(PARAM.inp.nbands) + 1.0e-8)
+        {
+            std::ostringstream oss;
+            oss << "CHGDATA target nelect=" << std::setprecision(12) << target_nelect
+                << " with nupdown=" << PARAM.inp.nupdown
+                << " exceeds the current two_fermi band capacity: nelec_up=" << nelec_up
+                << ", nelec_down=" << nelec_down
+                << ", nbands=" << PARAM.inp.nbands
+                << "; increase nbands in ABACUS INPUT";
+            ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect", oss.str());
+        }
+    }
+    else
+    {
+        const double max_nelect = 2.0 * static_cast<double>(PARAM.inp.nbands);
+        if (target_nelect > max_nelect + 1.0e-8)
+        {
+            std::ostringstream oss;
+            oss << "CHGDATA target nelect=" << std::setprecision(12) << target_nelect
+                << " exceeds the current band capacity 2*nbands=" << max_nelect
+                << "; increase nbands in ABACUS INPUT";
+            ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect", oss.str());
+        }
+    }
+
+    if ((flag & IPI_FLAG_NE_ELECTRODE) != 0)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect",
+                                 "ABACUS i-PI Ne-electrode CHGDATA is disabled in this constant-potential build");
+    }
+
+    const double nearest_integer = std::round(target_nelect);
+    if (std::abs(target_nelect - nearest_integer) > 1.0e-8 && PARAM.inp.smearing_method == "fixed")
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect",
+                                 "fractional CHGDATA electron numbers require a smearing occupation method");
+    }
+
+    if (p_esolver == nullptr)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect", "ESolver pointer is null");
+    }
+
+    if (!this->solvation_update_stride_declared_)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect",
+                                 "constant-potential CHGDATA requires solvation_update_stride in INIT");
+    }
+    const bool update_solvation = (flag & IPI_FLAG_SOLVATION) != 0;
+    if (this->solvation_update_stride_ == 1 && !update_solvation)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect",
+                                 "frozen-solvent CHGDATA is inconsistent with solvation_update_stride=1");
+    }
+    if (this->solvation_update_stride_ > 1)
+    {
+        if (!p_esolver->set_ipi_solvation_update(update_solvation))
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect",
+                                     "the selected ABACUS ESolver cannot schedule implicit-solvent updates");
+        }
+        if (!update_solvation && !p_esolver->ipi_solvation_cache_valid())
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect",
+                                     "frozen-solvent CHGDATA was received before a real solvent cache was built");
+        }
+    }
+    elecstate::ElecState* elec = p_esolver->get_elecstate();
+    if (elec == nullptr)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::apply_nelect",
+                                 "current ESolver does not expose an electronic state for CHGDATA");
+    }
+
+    PARAM.set_input_nelec(target_nelect);
+    elec->eferm.two_efermi = PARAM.globalv.two_fermi;
+    elec->init_nelec_spin();
+
+    if (is_root())
+    {
+        GlobalV::ofs_running << " @IPI DRIVER: Applied CHGDATA target_nelect="
+                             << std::setprecision(12) << target_nelect
+                             << " flag=" << flag << std::endl;
+    }
+}
+
+void IPIDriver::receive_posdata(IpiSocket& socket, UnitCell& ucell)
+{
+    std::int32_t nat = 0;
+    std::vector<double> cell_h(9, 0.0);
+    std::vector<double> cell_ih(9, 0.0);
+    std::vector<double> positions;
+
+    if (is_root())
+    {
+        socket.read_float64_array(cell_h.data(), cell_h.size());
+        socket.read_float64_array(cell_ih.data(), cell_ih.size());
+        socket.read_int32(nat);
+        if (nat <= 0)
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::receive_posdata", "received non-positive atom count from i-PI");
+        }
+        if (nat != ucell.nat)
+        {
+            std::ostringstream oss;
+            oss << "i-PI atom count " << nat << " differs from ABACUS STRU atom count " << ucell.nat;
+            ModuleBase::WARNING_QUIT("IPIDriver::receive_posdata", oss.str());
+        }
+        positions.resize(static_cast<std::size_t>(3 * nat));
+        socket.read_float64_array(positions.data(), positions.size());
+
+        if (!std::all_of(cell_h.begin(), cell_h.end(), [](double value) { return std::isfinite(value); })
+            || !std::all_of(cell_ih.begin(), cell_ih.end(), [](double value) { return std::isfinite(value); })
+            || !std::all_of(positions.begin(), positions.end(), [](double value) { return std::isfinite(value); }))
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::receive_posdata",
+                                     "POSDATA cell, inverse cell, and positions must be finite");
+        }
+    }
+
+    broadcast_posdata(cell_h, positions, nat);
+
+    if (nat != ucell.nat)
+    {
+        std::ostringstream oss;
+        oss << "i-PI atom count " << nat << " differs from ABACUS STRU atom count " << ucell.nat;
+        ModuleBase::WARNING_QUIT("IPIDriver::receive_posdata", oss.str());
+    }
+
+    update_cell(ucell, cell_h);
+    update_positions(ucell, positions);
+}
+
+void IPIDriver::broadcast_posdata(std::vector<double>& cell_h, std::vector<double>& positions, std::int32_t& nat) const
+{
+    broadcast_int32(nat);
+    if (!is_root())
+    {
+        cell_h.assign(9, 0.0);
+        if (nat > 0)
+        {
+            positions.assign(static_cast<std::size_t>(3 * nat), 0.0);
+        }
+    }
+    broadcast_double_array(cell_h.data(), static_cast<int>(cell_h.size()));
+    if (!positions.empty())
+    {
+        broadcast_double_array(positions.data(), static_cast<int>(positions.size()));
+    }
+}
+
+void IPIDriver::update_cell(UnitCell& ucell, const std::vector<double>& cell_h) const
+{
+    if (cell_h.size() != 9 || ucell.lat0 <= 0.0 || !std::isfinite(ucell.lat0))
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::update_cell", "invalid cell matrix or ABACUS lat0");
+    }
+
+    bool changed = false;
+    for (int i = 0; i < 3; ++i)
+    {
+        for (int j = 0; j < 3; ++j)
+        {
+            const double old_value = ucell.lat0 * cell_component(ucell.latvec, i, j);
+            // i-PI stores lattice vectors in columns, while ABACUS stores
+            // them in rows. Transpose the wire-format cell on input.
+            const double new_value = cell_h[3 * j + i];
+            if (std::abs(old_value - new_value) > CELL_TOL)
+            {
+                changed = true;
+            }
+        }
+    }
+
+    if (!changed)
+    {
+        return;
+    }
+
+    if (!PARAM.inp.cal_stress)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::update_cell",
+                                 "variable-cell POSDATA requires cal_stress = 1");
+    }
+
+    for (int i = 0; i < 3; ++i)
+    {
+        for (int j = 0; j < 3; ++j)
+        {
+            set_cell_component(ucell.latvec, i, j, cell_h[3 * j + i] / ucell.lat0);
+        }
+    }
+
+    ucell.cell_parameter_updated = true;
+    unitcell::setup_cell_after_vc(ucell, GlobalV::ofs_running);
+}
+
+void IPIDriver::update_positions(UnitCell& ucell, const std::vector<double>& positions) const
+{
+    if (positions.size() != static_cast<std::size_t>(3 * ucell.nat))
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::update_positions", "invalid POSDATA position array size");
+    }
+
+    int iat = 0;
+    for (int it = 0; it < ucell.ntype; ++it)
+    {
+        Atom* atom = &ucell.atoms[it];
+        for (int ia = 0; ia < atom->na; ++ia)
+        {
+            ModuleBase::Vector3<double> new_tau;
+            for (int ik = 0; ik < 3; ++ik)
+            {
+                new_tau[ik] = positions[3 * iat + ik] / ucell.lat0;
+                atom->dis[ia][ik] = new_tau[ik] - atom->tau[ia][ik];
+                atom->tau[ia][ik] = new_tau[ik];
+            }
+            atom->taud[ia] = atom->tau[ia] * ucell.GT;
+            ++iat;
+        }
+    }
+    if (iat != ucell.nat)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::update_positions", "internal atom count mismatch");
+    }
+
+    unitcell::periodic_boundary_adjustment(ucell.atoms, ucell.latvec, ucell.ntype);
+    ucell.bcast_atoms_tau();
+    ucell.ionic_position_updated = true;
+}
+
+void IPIDriver::compute_force(UnitCell& ucell, ModuleESolver::ESolver* p_esolver, int istep, ForceResult& result) const
+{
+    if (p_esolver == nullptr)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::compute_force", "ESolver pointer is null");
+    }
+    p_esolver->runner(ucell, istep);
+    if (!p_esolver->conv_esolver)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::compute_force",
+                                 "electronic calculation did not reach the requested SCF convergence");
+    }
+
+    result.energy = 0.5 * p_esolver->cal_energy();
+    if (!std::isfinite(result.energy))
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::compute_force", "ABACUS energy is not finite");
+    }
+    result.forces.assign(static_cast<std::size_t>(3 * ucell.nat), 0.0);
+
+    ModuleBase::matrix force_temp(ucell.nat, 3);
+    p_esolver->cal_force(ucell, force_temp);
+    for (int iat = 0; iat < ucell.nat; ++iat)
+    {
+        for (int idir = 0; idir < 3; ++idir)
+        {
+            const double force = 0.5 * force_temp(iat, idir);
+            if (!std::isfinite(force))
+            {
+                ModuleBase::WARNING_QUIT("IPIDriver::compute_force", "ABACUS force is not finite");
+            }
+            result.forces[3 * iat + idir] = force;
+        }
+    }
+
+    std::fill(result.virial, result.virial + 9, 0.0);
+    if (PARAM.inp.cal_stress)
+    {
+        if (!std::isfinite(ucell.omega) || ucell.omega <= 0.0)
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::compute_force", "ABACUS cell volume is not finite and positive");
+        }
+        ModuleBase::matrix stress_temp;
+        p_esolver->cal_stress(ucell, stress_temp);
+        for (int i = 0; i < 3; ++i)
+        {
+            for (int j = 0; j < 3; ++j)
+            {
+                const double virial = 0.5 * stress_temp(i, j) * ucell.omega;
+                if (!std::isfinite(virial))
+                {
+                    ModuleBase::WARNING_QUIT("IPIDriver::compute_force", "ABACUS virial is not finite");
+                }
+                result.virial[3 * i + j] = virial;
+            }
+        }
+    }
+
+    result.extras = make_extras_json(ucell, p_esolver);
+    result.valid = true;
+}
+
+double IPIDriver::get_fermi_level_eV(const elecstate::ElecState* elec) const
+{
+    if (elec == nullptr)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::get_fermi_level_eV", "electronic state is null");
+    }
+
+    double fermi_level_Ry = 0.0;
+    if (elec->eferm.two_efermi)
+    {
+        const double ef_up = elec->eferm.get_efval(0);
+        const double ef_down = elec->eferm.get_efval(1);
+        if (!std::isfinite(ef_up) || !std::isfinite(ef_down))
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::get_fermi_level_eV",
+                                     "ABACUS two_fermi levels are not finite");
+        }
+        fermi_level_Ry = 0.5 * (ef_up + ef_down);
+    }
+    else
+    {
+        fermi_level_Ry = elec->eferm.get_efval(0);
+    }
+
+    const double fermi_level_eV = fermi_level_Ry * ModuleBase::Ry_to_eV;
+    if (!std::isfinite(fermi_level_eV))
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::get_fermi_level_eV", "ABACUS Fermi level is not finite");
+    }
+    return fermi_level_eV;
+}
+
+std::string IPIDriver::make_extras_json(const UnitCell& ucell, const ModuleESolver::ESolver* p_esolver) const
+{
+    if (p_esolver == nullptr)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::make_extras_json", "ESolver pointer is null");
+    }
+
+    const elecstate::ElecState* elec = p_esolver->get_elecstate();
+    if (elec == nullptr)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::make_extras_json",
+                                 "current ESolver does not expose an electronic state for i-PI extras");
+    }
+
+    const double fermi_level_eV = get_fermi_level_eV(elec);
+    if (!std::isfinite(PARAM.inp.nelec) || PARAM.inp.nelec <= 0.0)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::make_extras_json",
+                                 "ABACUS electron number is not finite and positive");
+    }
+
+    std::ostringstream json;
+    json << std::setprecision(17)
+         << "{\"fermi_level_eV\":" << fermi_level_eV
+         << ",\"nelect\":" << PARAM.inp.nelec;
+
+    if (this->has_potential_average_region_)
+    {
+        const double average_electrostatic_Ry = p_esolver->electrostatic_potential_average(
+            ucell,
+            this->potential_average_axis_,
+            this->potential_average_min_A_,
+            this->potential_average_max_A_);
+        if (!std::isfinite(average_electrostatic_Ry))
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::make_extras_json",
+                                     "current ESolver cannot provide planar-averaged electrostatic potential");
+        }
+
+        const double average_electrostatic_eV = average_electrostatic_Ry * ModuleBase::Ry_to_eV;
+        const double workfunction_eV = average_electrostatic_eV - fermi_level_eV;
+        if (!std::isfinite(workfunction_eV))
+        {
+            ModuleBase::WARNING_QUIT("IPIDriver::make_extras_json", "ABACUS workfunction is not finite");
+        }
+
+        json << ",\"workfunction_eV\":" << workfunction_eV;
+        if (is_root())
+        {
+            GlobalV::ofs_running << " @IPI DRIVER: planar_average_electrostatic="
+                                 << std::setprecision(12) << average_electrostatic_eV
+                                 << " eV workfunction=" << workfunction_eV << " eV" << std::endl;
+        }
+    }
+
+    json << "}";
+    return json.str();
+}
+
+void IPIDriver::send_force(IpiSocket& socket, const UnitCell& ucell, const ForceResult& result) const
+{
+    if (!is_root())
+    {
+        return;
+    }
+
+    socket.send_header("FORCEREADY");
+    socket.write_float64(result.energy);
+    socket.write_int32(static_cast<std::int32_t>(ucell.nat));
+    socket.write_float64_array(result.forces.data(), result.forces.size());
+    socket.write_float64_array(result.virial, 9);
+    if (result.extras.size() > static_cast<std::size_t>(std::numeric_limits<std::int32_t>::max()))
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::send_force", "extras JSON is too large for i-PI protocol");
+    }
+    socket.write_int32(static_cast<std::int32_t>(result.extras.size()));
+    socket.write_string(result.extras);
+
+    GlobalV::ofs_running << " @IPI DRIVER: Sent force data to i-PI. energy(Ha)="
+                         << std::setprecision(12) << result.energy
+                         << " extras=" << result.extras << std::endl;
+}
+
+} // namespace ModuleIPI
