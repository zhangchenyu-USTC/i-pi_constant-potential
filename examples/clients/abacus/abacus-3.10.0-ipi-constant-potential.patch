+double cell_component(const ModuleBase::Matrix3& matrix, int i, int j)
+{
+    if (i == 0 && j == 0) return matrix.e11;
+    if (i == 0 && j == 1) return matrix.e12;
+    if (i == 0 && j == 2) return matrix.e13;
+    if (i == 1 && j == 0) return matrix.e21;
+    if (i == 1 && j == 1) return matrix.e22;
+    if (i == 1 && j == 2) return matrix.e23;
+    if (i == 2 && j == 0) return matrix.e31;
+    if (i == 2 && j == 1) return matrix.e32;
+    return matrix.e33;
+}
+
+void set_cell_component(ModuleBase::Matrix3& matrix, int i, int j, double value)
+{
+    if (i == 0 && j == 0) matrix.e11 = value;
+    else if (i == 0 && j == 1) matrix.e12 = value;
+    else if (i == 0 && j == 2) matrix.e13 = value;
+    else if (i == 1 && j == 0) matrix.e21 = value;
+    else if (i == 1 && j == 1) matrix.e22 = value;
+    else if (i == 1 && j == 2) matrix.e23 = value;
+    else if (i == 2 && j == 0) matrix.e31 = value;
+    else if (i == 2 && j == 1) matrix.e32 = value;
+    else matrix.e33 = value;
+}
+
+bool extract_init_double(const std::string& init_string, const std::string& key, double& value)
+{
+    const std::size_t key_pos = init_string.find(key);
+    if (key_pos == std::string::npos)
+    {
+        return false;
+    }
+
+    const std::size_t colon_pos = init_string.find(':', key_pos + key.size());
+    if (colon_pos == std::string::npos)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::handle_init", "INIT token '" + key + "' is missing ':'");
+    }
+
+    std::istringstream iss(init_string.substr(colon_pos + 1));
+    iss >> value;
+    if (iss.fail() || !std::isfinite(value))
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::handle_init", "INIT token '" + key + "' must be a finite number");
+    }
+    return true;
+}
+
+bool extract_init_string(const std::string& init_string, const std::string& key, std::string& value)
+{
+    const std::size_t key_pos = init_string.find(key);
+    if (key_pos == std::string::npos)
+    {
+        return false;
+    }
+    const std::size_t colon_pos = init_string.find(':', key_pos + key.size());
+    if (colon_pos == std::string::npos)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::handle_init", "INIT token '" + key + "' is missing ':'");
+    }
+    const std::size_t begin = init_string.find_first_not_of(" \t\r\n", colon_pos + 1);
+    if (begin == std::string::npos)
+    {
+        ModuleBase::WARNING_QUIT("IPIDriver::handle_init", "INIT token '" + key + "' is empty");
+    }
+    const std::size_t end = init_string.find_first_of(" ,\t\r\n", begin);
+    value = init_string.substr(begin, end == std::string::npos ? std::string::npos : end - begin);
+    return true;
+}
+
+std::string message_name(MessageType type)
+{
+    switch (type)
+    {
+    case MessageType::Status: return "STATUS";
+    case MessageType::Init: return "INIT";
+    case MessageType::PosData: return "POSDATA";
+    case MessageType::ChgData: return "CHGDATA";
+    case MessageType::GetForce: return "GETFORCE";
+    case MessageType::Exit: return "EXIT";
+    default: return "UNKNOWN";
+    }
+}
