+double ESolver_FP::electrostatic_potential_average(const UnitCell& ucell,
+                                                   int axis,
+                                                   double minimum_A,
+                                                   double maximum_A) const
+{
+    const char* function_name = "ESolver_FP::electrostatic_potential_average";
+    if (axis < 0 || axis > 2)
+    {
+        ModuleBase::WARNING_QUIT(function_name, "potential_average_axis must be x, y, or z");
+    }
+    if (!std::isfinite(minimum_A) || !std::isfinite(maximum_A) || maximum_A <= minimum_A)
+    {
+        ModuleBase::WARNING_QUIT(function_name,
+                                 "potential_average_region must be finite and satisfy max > min");
+    }
+    if (this->pelec == nullptr || this->pelec->charge == nullptr || this->pelec->pot == nullptr)
+    {
+        ModuleBase::WARNING_QUIT(function_name,
+                                 "electronic state, charge, or potential is not initialized");
+    }
+    if (this->pw_rhod == nullptr)
+    {
+        ModuleBase::WARNING_QUIT(function_name,
+                                 "dense charge FFT grid is not initialized");
+    }
+    if (PARAM.inp.nspin != 1 && PARAM.inp.nspin != 2)
+    {
+        ModuleBase::WARNING_QUIT(function_name,
+                                 "planar electrostatic-potential averaging supports only nspin=1 or nspin=2");
+    }
+
+    const double lattice[3][3] = {
+        {ucell.latvec.e11, ucell.latvec.e12, ucell.latvec.e13},
+        {ucell.latvec.e21, ucell.latvec.e22, ucell.latvec.e23},
+        {ucell.latvec.e31, ucell.latvec.e32, ucell.latvec.e33}};
+    const double determinant
+        = lattice[0][0] * (lattice[1][1] * lattice[2][2] - lattice[1][2] * lattice[2][1])
+          - lattice[0][1] * (lattice[1][0] * lattice[2][2] - lattice[1][2] * lattice[2][0])
+          + lattice[0][2] * (lattice[1][0] * lattice[2][1] - lattice[1][1] * lattice[2][0]);
+    const int first = (axis + 1) % 3;
+    const int second = (axis + 2) % 3;
+    const double cross[3] = {
+        lattice[first][1] * lattice[second][2] - lattice[first][2] * lattice[second][1],
+        lattice[first][2] * lattice[second][0] - lattice[first][0] * lattice[second][2],
+        lattice[first][0] * lattice[second][1] - lattice[first][1] * lattice[second][0]};
+    const double face_norm
+        = std::sqrt(cross[0] * cross[0] + cross[1] * cross[1] + cross[2] * cross[2]);
+    if (!std::isfinite(determinant) || !std::isfinite(face_norm) || face_norm <= 0.0
+        || ucell.lat0_angstrom <= 0.0)
+    {
+        ModuleBase::WARNING_QUIT(function_name, "cell lattice is singular or invalid");
+    }
+
+    // The coordinate is the perpendicular distance between constant-fractional-
+    // coordinate planes. This remains well defined for triclinic cells.
+    const double cell_height_A = ucell.lat0_angstrom * std::abs(determinant) / face_norm;
+    if (minimum_A < -1.0e-10 || maximum_A > cell_height_A + 1.0e-10)
+    {
+        std::ostringstream oss;
+        oss << "potential_average_region [" << minimum_A << ", " << maximum_A
+            << "] Angstrom is outside the cell " << static_cast<char>('x' + axis)
+            << "-axis height [0, " << cell_height_A << "] Angstrom";
+        ModuleBase::WARNING_QUIT(function_name, oss.str());
+    }
+
+    const int nspin = PARAM.inp.nspin;
+    const int nrxx = this->pw_rhod->nrxx;
+    const int nx = this->pw_rhod->nx;
+    const int ny = this->pw_rhod->ny;
+    const int nz = this->pw_rhod->nz;
+    const int nplane = this->pw_rhod->nplane;
+    const int startz_current = this->pw_rhod->startz_current;
+
+    if (nx <= 0 || ny <= 0 || nz <= 0 || nrxx < 0 || nplane < 0
+        || (nrxx > 0 && nplane <= 0))
+    {
+        ModuleBase::WARNING_QUIT(function_name, "invalid FFT grid dimensions for planar averaging");
+    }
+
+    ModuleBase::matrix vh(nspin, nrxx);
+    vh = elecstate::H_Hartree_pw::v_hartree(ucell,
+                                            const_cast<ModulePW::PW_Basis*>(this->pw_rhod),
+                                            nspin,
+                                            this->pelec->charge->rho);
+
+    ModuleBase::matrix v_efield;
+    const bool add_dipole = PARAM.inp.efield_flag > 0 && PARAM.inp.dip_cor_flag > 0;
+    if (add_dipole)
+    {
+        v_efield.create(nspin, nrxx);
+        v_efield = elecstate::Efield::add_efield(ucell,
+                                                 const_cast<const ModulePW::PW_Basis*>(this->pw_rhod),
+                                                 nspin,
+                                                 this->pelec->charge->rho,
+                                                 this->solvent);
+    }
+
+    const double* v_fixed = nullptr;
+    if (nrxx > 0)
+    {
+        v_fixed = this->pelec->pot->get_fixed_v();
+        if (v_fixed == nullptr)
+        {
+            ModuleBase::WARNING_QUIT(function_name,
+                                     "fixed local electrostatic potential is not initialized");
+        }
+        if (PARAM.inp.imp_sol && this->solvent.delta_phi == nullptr)
+        {
+            ModuleBase::WARNING_QUIT(function_name,
+                                     "implicit solvent is enabled but delta_phi is not initialized");
+        }
+    }
+
+    double local_sum = 0.0;
+    double local_count = 0.0;
+    for (int ir = 0; ir < nrxx; ++ir)
+    {
+        const int local_z = ir % nplane;
+        const int xy_index = ir / nplane;
+        const int grid_index[3] = {xy_index / ny, xy_index % ny, local_z + startz_current};
+        const int grid_size[3] = {nx, ny, nz};
+        const double coordinate_A
+            = (static_cast<double>(grid_index[axis]) + 0.5)
+              / static_cast<double>(grid_size[axis]) * cell_height_A;
+        if (coordinate_A < minimum_A || coordinate_A >= maximum_A)
+        {
+            continue;
+        }
+
+        double v_elecstat = vh(0, ir) + v_fixed[ir];
+        if (add_dipole)
+        {
+            v_elecstat += v_efield(0, ir);
+        }
+        if (PARAM.inp.imp_sol)
+        {
+            v_elecstat += this->solvent.delta_phi[ir];
+        }
+
+        local_sum += v_elecstat;
+        local_count += 1.0;
+    }
+
+#ifdef __MPI
+    MPI_Allreduce(MPI_IN_PLACE, &local_sum, 1, MPI_DOUBLE, MPI_SUM, POOL_WORLD);
+    MPI_Allreduce(MPI_IN_PLACE, &local_count, 1, MPI_DOUBLE, MPI_SUM, POOL_WORLD);
+#endif
+
+    if (local_count <= 0.0)
+    {
+        std::ostringstream oss;
+        oss << "no FFT grid points found in potential_average_region [" << minimum_A << ", " << maximum_A
+            << "] Angstrom; adjust potential_average_region or FFT grid";
+        ModuleBase::WARNING_QUIT(function_name, oss.str());
+    }
+
+    return local_sum / local_count;
+}
